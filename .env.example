# Supabase (get from: supabase.com → Project → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (get from: dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_PRO=price_...         # $59/mo product price ID
STRIPE_PRICE_BUSINESS=price_...    # $149/mo product price ID
STRIPE_WEBHOOK_SECRET=whsec_...    # from Stripe → Webhooks → endpoint secret

# App URL (no trailing slash)
VITE_APP_URL=https://clickinsights.ai
