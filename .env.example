# Supabase (get from: supabase.com → Project → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# LemonSqueezy (get from: app.lemonsqueezy.com)
LEMONSQUEEZY_API_KEY=your-api-key-here
LEMONSQUEEZY_STORE_ID=your-store-id-here
LEMONSQUEEZY_VARIANT_PRO=1890909
LEMONSQUEEZY_VARIANT_BUSINESS=1890911
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret-here

# App URL (no trailing slash)
VITE_APP_URL=https://clickinsights.ai
